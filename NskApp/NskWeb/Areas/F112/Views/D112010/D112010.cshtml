                    <button type="button" class="btn btn-warning mt_15" id="AcceptFile" style="width: 100px !important;">受入</button>
                </div>
            </div>
        </div>
    </div>
}
    <div class="split_line" id="@CoreConst.SEARCH_RESULT_DIV_ID"></div>
