@model NskWeb.Areas.F111.Models.D111050.D111050Model
@{
    var startIndex = 700;
    int tabIndex = startIndex;
}


<div class="table-thead-container" style="width: 70%;">
    <table class="table table-bordered" style="">
        <thead style="background-color: #ecf1fb;">
            <tr>
                <th>共済目的</th>
                <th>引受報告回</th>
                <th>農家負担掛金</th>
                <th>
                    徴収済み額
                    <i class="required">必須</i>
                </th>
                <th>徴収割合</th>
            </tr>
        </thead>
        <tbody id ="KakekinChoshugakuTableBody">
            @for (int i = 0; i < Model.KakekinChoshugaku.DispRecords.Count(); i++)
            {
                <!-- 行ｎ -->
                <tr>
                    <td id="@Html.IdFor(model => model.KakekinChoshugaku.DispRecords[i].KyosaiMokuteki)">
                        @Html.HiddenFor(model => model.KakekinChoshugaku.DispRecords[i].KofuChoshuXmin)
                        @Html.HiddenFor(model => model.KakekinChoshugaku.DispRecords[i].KofukaiXmin)
                        @Html.HiddenFor(model => model.KakekinChoshugaku.DispRecords[i].KyosaiMokutekiCd)
                        @Html.DisplayTextFor(model => model.KakekinChoshugaku.DispRecords[i].KyosaiMokuteki)
                    </td>
                    <td id="@Html.IdFor(model => model.KakekinChoshugaku.DispRecords[i].HikiukeHoukokukai)" style="text-align: right;">
                        @Html.HiddenFor(model => model.KakekinChoshugaku.DispRecords[i].HikiukeHoukokukai)
                        @Html.DisplayFor(model => model.KakekinChoshugaku.DispRecords[i].HikiukeHoukokukai, "",
                                 new { htmlAttributes = new { @class = "text-end" } })
                    </td>
                    <td id="@Html.IdFor(model => model.KakekinChoshugaku.DispRecords[i].Futankin)" style="text-align: right;">
                        @Html.HiddenFor(model => model.KakekinChoshugaku.DispRecords[i].Futankin)
                        @Html.DisplayFor(model => model.KakekinChoshugaku.DispRecords[i].Futankin, "",
                                 new { htmlAttributes = new { @class = "text-end" } })
                    </td>
                    <td id="@Html.IdFor(model => model.KakekinChoshugaku.DispRecords[i].ChoshuzumiGaku)" style="text-align: right;">
                        @Html.EditorFor(model => model.KakekinChoshugaku.DispRecords[i].ChoshuzumiGaku, "",
                                 new { htmlAttributes = new { @class = "form-control text-end number-add-comma inputrequired", tabindex = tabIndex++, @type = "text", maxlength = "12" } })
                    </td>
                    <td id="@Html.IdFor(model => model.KakekinChoshugaku.DispRecords[i].ChoshuWariai)" style="text-align: right;">
                        @Html.DisplayFor(model => model.KakekinChoshugaku.DispRecords[i].ChoshuWariai, "",
                                 new { htmlAttributes = new { @class = "text-end" } })%
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>