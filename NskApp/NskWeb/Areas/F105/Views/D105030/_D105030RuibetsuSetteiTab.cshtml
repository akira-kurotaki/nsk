@model NskWeb.Areas.F105.Models.D105030.D105030Model
@{
    var startIndex = 500;
    int tabIndex = startIndex;

    string[] kengens = ["一部権限", "更新権限"];
    string buttonDisableAttr = "";
    if (!kengens.Contains(Model.DispKengen))
    {
        buttonDisableAttr = "disabled";
    }
}

<div id="RuibetuSettei" class="tab-pane" role="tabpanel" aria-labelledby="RuibetuSetteiTab">
    <!-- 類別設定 -->
    @using (Html.BeginForm("Init", "NSK105030D", FormMethod.Post, new { id = "RuibetuSetteiForm", spellcheck = "false", autocomplete = "off" }))
    {
        @await Html.PartialAsync("_HiddenWindowId")
        <div class="table-thead-container">
            <h4 class="sub_title">類別設定</h4>
            <div class="btn_area btn_group_left">
                <button type="button" class="btn btn-primary" id="AddRuibetsuRow" name="AddRuibetsuRow" @buttonDisableAttr>行挿入</button>
                <button type="button" class="btn btn-primary" id="DelRuibetsuRows" name="DelRuibetsuRows" @buttonDisableAttr>選択行削除</button>
                <button type="button" class="btn btn-primary" id="SelAllRuibetsu" name="SelAllRuibetsu" @buttonDisableAttr>全行選択</button>
                <button type="button" class="btn btn-primary" id="UnSelAllRuibetsu" name="UnSelAllRuibetsu" @buttonDisableAttr>全行解除</button>
            </div>
            <div class="clearfix"></div>
            <div id="RuibetsuSetteiResult">
                @await Html.PartialAsync("_D105030RuibetsuSetteiResult", Model)
            </div>
            <div class="table-responsive table-thead-container">
                <div class="btn_area btn_group_right">
                    <button type="button" class="btn btn-primary" id="RegistRuibetsu" name="RegistRuibetsu" @buttonDisableAttr>
                        登録
                    </button>
                </div>
            </div>
        </div>
    }

    @using (Html.BeginForm("Init", "NSK105030D", FormMethod.Post, new { id = "KikenDankaiKbnForm", spellcheck = "false", autocomplete = "off" }))
    {
        <div class="table-thead-container">
            <h4 class="sub_title">統計単位地域コード危険段階区分入力</h4>
            <div class="btn_area btn_group_left">
                <button type="button" class="btn btn-primary" id="AddTokeiTaniRow" name="AddTokeiTaniRow" @buttonDisableAttr>行挿入</button>
                <button type="button" class="btn btn-primary" id="DelTokeiTaniRows" name="DelTokeiTaniRows" @buttonDisableAttr>選択行削除</button>
                <button type="button" class="btn btn-primary" id="SelAllTokeiTani" name="SelAllTokeiTani" @buttonDisableAttr>全行選択</button>
                <button type="button" class="btn btn-primary" id="UnSelAllTokeiTani" name="UnSelAllTokeiTani" @buttonDisableAttr>全行解除</button>
            </div>
            <div class="clearfix"></div>
            <div id="KikenDankaiKbnResult">
                @await Html.PartialAsync("_D105030KikenDankaiKbnResult", Model)
            </div>
            <div class="table-responsive table-thead-container">
                <div class="btn_area btn_group_right">
                    <button type="button" class="btn btn-primary" id="RegistTokeiTani" name="RegistTokeiTani" @buttonDisableAttr>
                        登録
                    </button>
                </div>
            </div>
        </div>
    }
</div>