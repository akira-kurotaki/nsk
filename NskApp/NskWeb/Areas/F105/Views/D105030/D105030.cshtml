            @* 共通申請割引方法ドロップダウンリスト値変更時 *@
            $("#KumiaiintoSettei_KyotuShinseiWaribikiHouho").change(function() {
                var url = "@Url.Action("UpdateWaribikiHouhou", "D105030", new { area = "F105" })";
                var kyotuShinseiWaribikiHouhoCd = $('#KumiaiintoSettei_KyotuShinseiWaribikiHouho option:selected').val();

                $.ajax({
                    url: url,
                    dataType: 'json',
                    contentType: "application/json; charset=utf-8",
                    type: 'GET',
                    async: false,
                    cache: false,
                    data: { kyotuShinseiWaribikiHouhoCd: kyotuShinseiWaribikiHouhoCd }
                }).done(function (data) {
                    if (data != null) {
                        // １．２．割引割合、割引金額、割増割合、割増金額に取得した値を設定する。
                        // ２．２．割引割合、割引金額、割増割合、割増金額、共通申請等割引理由に取得した値を設定する。

                        $("#KumiaiintoSettei_WaribikiWariai").val(`${data.waribikiWariai}%`);
                        $("#KumiaiintoSettei_WaribikiKingaku").val(`${data.waribikiKingaku}`);
                        $("#KumiaiintoSettei_WarimashiWariai").val(`${data.warimashiWariai}%`);
                        $("#KumiaiintoSettei_WarimashiKingaku").val(`${data.warimashiKingaku}`);
                        $("#KumiaiintoSettei_KyotuShinseitoWaribikiRiyu").val(data.kyotuShinseitoWaribikiRiyu);

                        // カンマ編集機能再設定
                        loadNumberAddComma();
                    }

                    if (kyotuShinseiWaribikiHouhoCd != "99") {
                        // １．選択値が「99：個人設定」以外の場合、

                        // １．３．共通申請等割引理由に空白を設定する。
                        $("#KumiaiintoSettei_KyotuShinseitoWaribikiRiyu").val("");

                        // １．４．割引割合、割引金額、割増割合、割増金額、共通申請等割引理由を非活性（入力不可）にする。
                        $("#KumiaiintoSettei_WaribikiWariai").attr('readonly', 'readonly');
                        $("#KumiaiintoSettei_WaribikiKingaku").attr('readonly', 'readonly');
                        $("#KumiaiintoSettei_WarimashiWariai").attr('readonly', 'readonly');
                        $("#KumiaiintoSettei_WarimashiKingaku").attr('readonly', 'readonly');
                        $("#KumiaiintoSettei_KyotuShinseitoWaribikiRiyu").attr('readonly', 'readonly');

                    } else {
                        // ２．選択値が「99：個人設定」の場合、

                        // ２．３．割引割合、割引金額、割増割合、割増金額、共通申請等割引理由を活性（入力可）にする。
                        $("#KumiaiintoSettei_WaribikiWariai").removeAttr('readonly');
                        $("#KumiaiintoSettei_WaribikiKingaku").removeAttr('readonly');
                        $("#KumiaiintoSettei_WarimashiWariai").removeAttr('readonly');
                        $("#KumiaiintoSettei_WarimashiKingaku").removeAttr('readonly');
                        $("#KumiaiintoSettei_KyotuShinseitoWaribikiRiyu").removeAttr('readonly');

                    }

                }).fail(function () {
                    location.href = "@Url.Action("Init", "D900002", new { area = "F900" })";
                });

            });
        });

