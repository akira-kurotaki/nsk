            @* 統計単位地域コード、危険段階区分登録 統計単位地域コード、危険段階区分の入力内容を登録する。*@
            $("#RegistTokeiTani").click(function() {
                var messageArea6 = $("span[data-valmsg-for='MessageArea6']");
                // 前回のメッセージをクリアする
                messageArea6.html("");
                var message = "";

                if ("" != message) {
                    $("html, body").scrollTop(0);
                }

                // １．入力チェック
                // １．１．属性チェック
                var checkValid = $("#KikenDankaiKbnForm").valid();
                if (!checkValid) {
                    // エラーチェック仕様に基づき各項目のチェックを行う。
                    // １．１．１．エラーの場合
                    //    エラーが発生した各入力欄の直下にメッセージを表示する。
                    return;
                }

                // ２．エラーがない場合、以下のダイアログを表示する。
                if ($("#KikenDankaiKbnForm").valid() && "" == message) {
                    @Html.ShowDialog("RegistTokeiTaniConfirm");
                }
            });
            $("#RegistTokeiTaniConfirmOK").click(function() {
                // ２．１．１．「OK」を押下時
                // ２．１．１．類別設定入力フォームの入力データをJSON化する
                //    ※数値項目はカンマを除去する
                // ２．１．２．入力データ（JSON形式）を送信する。
                var url = "@Url.Action("RegistTokeiTani", "D105030", new { area = "F105" })";
                var formData = new FormData($("#KikenDankaiKbnForm").get(0));

                $.ajax({
                    type: 'POST',
                    cache: false,
                    data: formData,
                    dataType: 'json',
                    url: url,
                    processData: false,  //ajaxがdataを整形しない指定
                    contentType: false  //contentTypeもfalseに指定
                }).done(function (data) {
                    if (data.message != null && data.message.indexOf('完了') < 0) {
                        $('#MessageArea6').addClass("text-danger").html(data.message);
                    }
                    else {
                        $('#MessageArea6').removeClass("text-danger").html(data.message);
                    }
                    $("html, body").scrollTop($('#KikenDankaiKbnForm').offset().top);
                }).fail(function () {
                    location.href = "@Url.Action("Init", "D900002", new { area = "F900" })";
                });
            });

            @* GIS項目チェックボックス変更時処理 GIS項目のチェックボックス状態に応じて入力欄の活性・非活性を変更する。*@
            $("#accordionGisInput input[type='checkbox']").change(function() {
                // UpdateGisInput
                var key = this.id;
                var checked = this.checked;
                key = key.replace("SearchCondition_Check", "");
                var gisValKey = `#SearchCondition_Ikkatsu${key}`;
                if (checked) {
                    // 活性にする
                    $(gisValKey)[0].readOnly = false;
                } else {
                    // 非活性にする
                    $(gisValKey)[0].readOnly = true;
                }
            });

            @* 引受情報チェック 入力内容が妥当かチェック処理を行う。*@
            $("#CheckHikiuke").click(function() {
                $('#MessageArea1').html("");

                var url = "@Url.Action("CheckHikiuke", "D105030", new { area = "F105" })";

                $.ajax({
                    type: 'GET',
                    url: url,
                    data: null,
                    dataType: 'json',
                    contentType: "application/json",
                    cache: false,
                }).done(function (data) {
                    if (data.result != 0 && data.message != null) {
                        $('#MessageArea1').addClass("text-danger").html(data.message);
 
                    } else if (data.result == 0 && data.message != null) {
                        $('#MessageArea1').removeClass("text-danger").html(data.message);

                    }
                    $("html, body").scrollTop(0);
                }).fail(function () {
                    location.href = "@Url.Action("Init", "D900002", new { area = "F900" })";
                });
            });

