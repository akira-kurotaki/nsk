                <td>
                    <table style="width:100%">
                        <tr>
                            <td style="width:45%">
                                @Html.EditorFor(model => model.SearchCondition.KumiaiinToCdFrom, "",
                                         new { htmlAttributes = new { @class = "form-control", tabindex = 108, @type = "text" } })
                            </td>
                            <td class="text-center" style="width:10%">
                                <div>～</div>
                            </td>
