                </td>
                <td>
                    @Html.DropDownListFor(model => model.SearchCondition.RuiKbn, 
                        Model.SearchCondition.RuiKbnList,
                        "", new { @class = "form-select form-select-lg", tabindex = 100, @title = "選択項目" })
