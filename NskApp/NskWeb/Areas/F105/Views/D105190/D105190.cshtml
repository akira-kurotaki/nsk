                checkboxs.prop('checked', true);

                // フォーカスは先頭行の先頭項目に当てる
                let idx = 0;
                for (idx = 0; idx < checkboxs.length; idx++) {
                    // チェックボックスのあるTDの親であるTRのstyleに「display: none;」が設定されていない場合、表示行となる
                    if (checkboxs[idx].parentNode.parentNode.style["display"] != "none") {
