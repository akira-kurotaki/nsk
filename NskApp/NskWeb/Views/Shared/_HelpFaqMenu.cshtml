@{
    var helpMenu = SessionUtil.Get<List<HelpMenuItem>>(CoreConst.SESS_HELP_MENU_LIST, this.Context) == null ? new List<HelpMenuItem>() : SessionUtil.Get<List<HelpMenuItem>>(CoreConst.SESS_HELP_MENU_LIST, this.Context);
}
<i></i>
@if (helpMenu != null)
{
    <ul>
        @foreach (var item in helpMenu)
        {
            <li>
                <a href="javascript: windowSizeOpen('@Url.Action("HelpLink", "C000000", new { area = "F000" })?hh=@item.Hash', 'help', window.outerWidth, window.outerHeight);closeNavi();">
                    <i class="bi bi-file-earmark-fill"></i><em>@item.Text</em>
                </a>
            </li>
        }
    </ul>
}