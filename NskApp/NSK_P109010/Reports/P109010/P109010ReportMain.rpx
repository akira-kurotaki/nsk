  <ReportComponentTray />
  <Script><![CDATA[/*' 2018/10/22 エラートラップMsgBox標準化

Option Compare Database
Option Explicit

Dim i As Integer                    ' 現在の出力行
Dim j As Integer                    ' レコード件数
Const MAX_LINE As Integer = 22      '「４．耕地等情報」出力行数
Dim intWKPage As Integer            ' グループ（組合員等コードごと）の1頁目
Dim int年産 As Integer              ' タイトル表示用年産
'

Private Sub グループヘッダー0_Format(Cancel As Integer, FormatCount As Integer)
    On Error GoTo Err_グループヘッダー0_Format
    
    Const TWIP_CM As Integer = 567      ' 1 cm = 567 Twip
    Dim dblTop1 As Double
    Dim dblOffset As Double
    Dim intFontSize As Integer
    Dim intKanjiNameLenB As Integer
    
    If FormatCount = 1 Then
        intWKPage = Me.Page
    End If
    
    ' 文字数に応じて氏名欄テキストボックスのFontSize、Topを調整
    intKanjiNameLenB = LenB(StrConv(Nz(Me![txt申込者氏名], ""), vbFromUnicode))
    dblTop1 = 5.8   '20230406 位置調整6.1→

    If intKanjiNameLenB <= 14 Then
        dblOffset = 0
        intFontSize = 20
    ElseIf intKanjiNameLenB <= 20 Then
        dblOffset = 0.1
        intFontSize = 18
    ElseIf intKanjiNameLenB <= 24 Then
        dblOffset = 0.15
        intFontSize = 16
    ElseIf intKanjiNameLenB <= 30 Then
        dblOffset = 0.18
        intFontSize = 14
    ElseIf intKanjiNameLenB <= 38 Then
        dblOffset = 0.21
        intFontSize = 12
    Else
        dblOffset = 0
        intFontSize = 12
    End If
    
    Me!txt申込者氏名.Top = (dblTop1 + dblOffset) * TWIP_CM
    Me!txt申込者氏名.FontSize = intFontSize

    Dim strSQL As String
    i = 0
    
    strSQL = "[年産] = " & Me![txt年産] & _
             " AND [共済目的コード] = " & Me![txt共済目的コード] & _
             " AND [組合員等コード] = " & Me![txt組合員等番号]
    j = DCount("*", "NSK_V_加入申込書", strSQL)
    
    Me!pb詳細.Visible = False
    Me.ページヘッダーセクション.Visible = False

    Me!txtタイトル用年産 = int年産
    
Exit_グループヘッダー0_Format:
    Exit Sub
Err_グループヘッダー0_Format:
    MsgBox Err & ":" & Error$ & "(Sub グループヘッダー0_Format)" _
           , vbCritical + vbOKOnly, Me.Caption
    Resume Exit_グループヘッダー0_Format
End Sub

Private Sub Report_Open(Cancel As Integer)
    On Error GoTo Err_Report_Open
    '帳票抽出起動時対応　"F3"はレポートによって異なる
    If IsFormOpen("F-SH00-帳票選択") Then
        Forms![F-SH00-帳票選択].Visible = False
    End If
    
    intWKPage = 0
    
    int年産 = ParamConv(Me.OpenArgs, 2)
    
Exit_Report_Open:
    Exit Sub
Err_Report_Open:
    MsgBox Err & ":" & Error$ & "(Sub Report_Open)" _
           , vbCritical + vbOKOnly, Me.Caption
    Resume Exit_Report_Open
End Sub

Private Sub Report_Page()
    On Error GoTo Err_Report_Page

    '帳票抽出起動時対応　オブジェクト名はレポートによって異なる
    '組合引受：F-SH00-帳票選択、組合等評価＆組合等特例：F-SS00-帳票選択、組合等無事戻：F-SB00-帳票選択
    '連合会評価&連合会特例：F-SS00-帳票選択
    DoCmd.OpenForm "S-SH00-帳票選択", acNormal, , , , , Me.Name
    
Exit_Report_Page:
    Exit Sub
Err_Report_Page:
    MsgBox Err & ":" & Error$ & "(Sub Report_Page)" _
           , vbCritical + vbOKOnly, Me.Caption
    Resume Exit_Report_Page
End Sub

Private Sub Report_Close()
    On Error GoTo Err_Report_Close
    Application.Echo False
    '印刷ダイアログ連動クローズ
    DoCmd.Close acForm, "S-SH00-帳票選択", acSaveNo
    
    'メニュー最大化　単体起動対応(null)
    If IsNull(Me.OpenArgs) = False Then
        DoCmd.SelectObject acForm, ParamConv(Me.OpenArgs, 1)
    End If
    
    '帳票抽出起動時対応　オブジェクト名はレポートによって異なる
    '組合引受：F-SH00-帳票選択、組合等評価＆組合等特例：F-SS00-帳票選択、組合等無事戻：F-SB00-帳票選択
    '連合会評価&連合会特例：F-SS00-帳票選択
    If IsFormOpen("F-SH00-帳票選択") Then
        Forms![F-SH00-帳票選択].Visible = True
    End If
    
    Application.Echo True

Exit_Report_Close:
    Exit Sub
Err_Report_Close:
    Application.Echo True
    MsgBox Err & ":" & Error$ & "(Sub Report_Close)" _
           , vbCritical + vbOKOnly, Me.Caption
    Resume Exit_Report_Close
End Sub

Function Get_Page()
    On Error GoTo Err_Get_Page
    
    Get_Page = Me.Page - intWKPage + 1
    
Exit_Get_Page:
    Exit Function
Err_Get_Page:
    MsgBox Err & ":" & Error$ & "(Function Get_Page)" _
           , vbCritical + vbOKOnly, Me.Caption
    Resume Exit_Get_Page
End Function

Private Sub レポートヘッダー_Format(Cancel As Integer, FormatCount As Integer)
    On Error GoTo Err_レポートヘッダー_Format

    Me.ページヘッダーセクション.Visible = False

Exit_レポートヘッダー_Format:
    Exit Sub
Err_レポートヘッダー_Format:
    MsgBox Err & ":" & Error$ & "(Sub レポートヘッダー_Format)" _
           , vbCritical + vbOKOnly, Me.Caption
    Resume Exit_レポートヘッダー_Format
End Sub

Private Sub 詳細_Format(Cancel As Integer, FormatCount As Integer)
    On Error GoTo Err_詳細_Format

    ' 出力済みで2重読み込みされたレコードは処理せずスキップ
    If (FormatCount > 1) And (i < j) Then
        GoTo Exit_詳細_Format
    End If
    
    i = i + 1
            
    If i Mod MAX_LINE = 0 Then
        Me!lastLine.BorderWidth = 2
        If i < j Then
            Me!pb詳細.Visible = True
            Me.ページヘッダーセクション.Visible = True
        ElseIf i = j Then
            Me!pb詳細.Visible = False
            Me.ページヘッダーセクション.Visible = False
        Else
            Call VisibleSettingOutputArea(False)
            Me.ページヘッダーセクション.Visible = False
        End If
    Else
        Me!lastLine.BorderWidth = 1
        Me!pb詳細.Visible = False
        Me.ページヘッダーセクション.Visible = False
        If i < j Then
            Me.NextRecord = True
            Call VisibleSettingOutputArea(True)
        ElseIf i = j Then
            Me.NextRecord = False
            Call VisibleSettingOutputArea(True)
        Else
            Me.NextRecord = False
            Call VisibleSettingOutputArea(False)
        End If
    End If
    
Exit_詳細_Format:
    Exit Sub
Err_詳細_Format:
    MsgBox Err & ":" & Error$ & "(Sub 詳細_Format)" _
           , vbCritical + vbOKOnly, Me.Caption
    Resume Exit_詳細_Format
End Sub

Private Sub VisibleSettingOutputArea(isVisible As Boolean)
    On Error GoTo Err_VisibleSettingOutputArea

    Me!txt耕地番号.Visible = isVisible
    Me!txt分筆番号.Visible = isVisible
    Me!txt市町村名.Visible = isVisible
    Me!txt地名地番.Visible = isVisible
    Me!txt耕地面積.Visible = isVisible
    Me!txt引受面積.Visible = isVisible
    Me!txt転作等面積.Visible = isVisible
    Me!txt類区分.Visible = isVisible
    Me!txt品種.Visible = isVisible
    Me!txt田畑区分.Visible = isVisible
    Me!txt備考.Visible = isVisible
    Me!txt収量等級.Visible = isVisible
    Me!txt参酌.Visible = isVisible
    
Exit_VisibleSettingOutputArea:
    Exit Sub
Err_VisibleSettingOutputArea:
    MsgBox Err & ":" & Error$ & "(Sub VisibleSettingOutputArea)" _
           , vbCritical + vbOKOnly, Me.Caption
    Resume Exit_VisibleSettingOutputArea
End Sub

Private Sub Report_KeyDown(KeyCode As Integer, Shift As Integer)
    On Error GoTo Err_Report_KeyDown

    Select Case KeyCode
        Case vbKeyF1 To vbKeyF16
            KeyCode = 0
    End Select
    
Exit_Report_KeyDown:
    Exit Sub
Err_Report_KeyDown:
    MsgBox Err & ":" & Error$ & "(Sub Report_KeyDown)" _
           , vbCritical + vbOKOnly, Me.Caption
    Resume Exit_Report_KeyDown
End Sub
*/public void GroupHeader1_Format()
{
	
}


public void 詳細_Format()
{
	
}


public void GroupHeader2_Format()
{
	
}


]]></Script>
